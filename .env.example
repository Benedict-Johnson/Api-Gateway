# ==========================
# API Gateway Configuration
# ==========================

# Authentication
# Secret key used for signing and verifying JWT tokens (must not be empty or 'change-me' in production)
JWT_SECRET=change-me
# Secret key used for internal service-to-gateway API authentication
API_KEY_SECRET=change-me

# Redis
# Redis server hostname (use 'redis' in Docker, 'localhost' for local development)
REDIS_HOST=redis
# Redis server port
REDIS_PORT=6379
# Redis password if authentication is required (leave blank if none)
REDIS_PASSWORD=

# Database
# PostgreSQL or Database connection string URL
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/gateway

# Gateway
# Operating environment: development, staging, production
ENVIRONMENT=development
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# TEMPORARY DOCUMENTATION / DEMO MODE: Bypasses auth, RBAC, and rate limits for screenshot generation. Must be false in production!
DEMO_MODE=false

# Security
# Enable TLS encryption for secure traffic
ENABLE_TLS=false